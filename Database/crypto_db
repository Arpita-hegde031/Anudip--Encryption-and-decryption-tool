use crypto_db;

-- 1. Create the database
CREATE DATABASE IF NOT EXISTS crypto_db;
USE crypto_db;

-- 2. Create the 'users' table 
-- This matches your second screenshot with id, email, password, and username
CREATE TABLE IF NOT EXISTS users (
    id INT AUTO_INCREMENT PRIMARY KEY,
    email VARCHAR(150) UNIQUE,
    password VARCHAR(255) NOT NULL, -- Storing the AES/Base64/Reverse string
    username VARCHAR(100)
);

-- 3. Create the 'user' table (Optional: if you need the secondary table from your image)
CREATE TABLE IF NOT EXISTS user (
    id INT AUTO_INCREMENT PRIMARY KEY,
    password VARCHAR(255) NOT NULL,
    username VARCHAR(100)
);

show tables;

select * from user;
select * from users;
